<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.MyAunt" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/md_surface</item>
        <item name="colorPrimary">@color/md_primary</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorSecondary">@color/md_secondary</item>
        <item name="colorSurface">@color/md_surface</item>
        <item name="colorOnSurface">@color/md_on_surface</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:windowBackground">@color/md_bg</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.MyAunt.Dialog</item>
    </style>

    <style name="ThemeOverlay.MyAunt.Dialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorPrimary">@color/md_primary</item>
        <item name="colorOnSurface">@color/md_on_surface</item>
    </style>

    <style name="Theme.MyAunt.Splash" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">#FFFFF8FC</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:windowBackground">@drawable/bg_splash_gradient</item>
        <item name="android:windowFullscreen">false</item>
    </style>

    <!-- 仅用于「添加小组件」快捷方式：不展示主界面 -->
    <style name="Theme.MyAunt.WidgetPinTrampoline" parent="android:Theme.Translucent.NoTitleBar">
        <item name="android:windowAnimationStyle">@null</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
    </style>
</resources>
