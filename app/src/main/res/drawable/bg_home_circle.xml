<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <size android:width="280dp" android:height="280dp" />
            <stroke android:width="4dp" android:color="#FFD4E3" android:dashWidth="8dp" android:dashGap="8dp" />
        </shape>
    </item>
    <item>
        <rotate android:fromDegrees="135" android:toDegrees="135">
            <shape android:shape="oval">
                <size android:width="280dp" android:height="280dp" />
                <stroke android:width="8dp" android:color="#FA5A7A" />
            </shape>
        </rotate>
    </item>
</layer-list>
