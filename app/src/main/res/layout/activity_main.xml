<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_hand_pattern"
    android:clipChildren="false">

    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:clipChildren="false"
        android:clipToPadding="false">

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Top Pink Border Line -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/ui_nav_divider" />

        <FrameLayout
            android:id="@+id/bottomNavContainer"
            android:layout_width="match_parent"
            android:layout_height="@dimen/bottom_nav_bar_height"
            android:background="@color/ui_nav_bar"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:paddingBottom="0dp">

            <com.google.android.material.bottomnavigation.BottomNavigationView
                android:id="@+id/bottom_nav"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="bottom"
                android:background="@android:color/transparent"
                app:elevation="0dp"
                app:itemRippleColor="@color/md_pink_soft"
                app:menu="@menu/bottom_nav_menu"
                app:itemTextColor="@color/nav_item_color"
                app:itemIconTint="@color/nav_item_color"
                app:labelVisibilityMode="labeled"
                app:itemIconSize="24dp"
                app:itemTextAppearanceActive="@style/BottomNavText"
                app:itemTextAppearanceInactive="@style/BottomNavText" />

            <!-- 中间「添加」与 doc 一致：圆形按钮 + 文案 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal|top"
                android:layout_marginTop="-22dp"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/centerAddButton"
                    android:layout_width="@dimen/fab_size"
                    android:layout_height="@dimen/fab_size"
                    app:cardBackgroundColor="@color/md_primary"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="@dimen/fab_elevation"
                    app:strokeColor="@color/ui_fab_stroke"
                    app:strokeWidth="4dp">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:contentDescription="@string/cd_record_period_fab"
                        android:src="@drawable/ic_plus"
                        app:tint="@android:color/white" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="添加"
                    android:textColor="@color/md_primary_soft"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </FrameLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
