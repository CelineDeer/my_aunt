<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/md_surface"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/ui_chart_history_row_stroke"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <FrameLayout
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_cycle_day_tag"
            android:backgroundTint="@color/ui_chart_history_icon_bg">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:src="@drawable/ic_chart"
                app:tint="@color/md_primary" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvHistoryTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/md_on_surface"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="3月周期" />

            <TextView
                android:id="@+id/tvHistorySubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/md_text_secondary"
                android:textSize="10sp"
                tools:text="03.12 起 · 周期间隔 29 天" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvHistoryInterval"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/md_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            tools:text="29天" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
