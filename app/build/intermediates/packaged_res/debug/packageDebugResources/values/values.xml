        <item name="android:letterSpacing">0.02</item>
    </style>
    <style name="Theme.MyAunt" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/md_surface</item>
        <item name="colorPrimary">@color/md_primary</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorSecondary">@color/md_secondary</item>
        <item name="colorSurface">@color/md_surface</item>
        <item name="colorOnSurface">@color/md_on_surface</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:windowBackground">@color/md_bg</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.MyAunt.Dialog</item>
    </style>
    <style name="Theme.MyAunt.Splash" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">#FFFFF8FC</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:windowBackground">@drawable/bg_splash_gradient</item>
        <item name="android:windowFullscreen">false</item>
    </style>
    <style name="Theme.MyAunt.WidgetPinTrampoline" parent="android:Theme.Translucent.NoTitleBar">
        <item name="android:windowAnimationStyle">@null</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
    </style>
    <style name="ThemeOverlay.MyAunt.Dialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorPrimary">@color/md_primary</item>
        <item name="colorOnSurface">@color/md_on_surface</item>
    </style>
    <style name="Widget.MyAunt.Chip.ReasonTag" parent="Widget.Material3.Chip.Filter">
        <item name="android:textAppearance">@style/TextAppearance.MyAunt.ChipReason</item>
        <item name="android:textColor">@color/chip_reason_text</item>
        <item name="chipBackgroundColor">@color/chip_reason_background</item>
        <item name="chipStrokeColor">@color/chip_reason_stroke</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="chipCornerRadius">22dp</item>
        <item name="chipMinHeight">44dp</item>
        <item name="chipStartPadding">16dp</item>
        <item name="chipEndPadding">16dp</item>
        <item name="checkedIconVisible">false</item>
        <item name="rippleColor">@color/md_pink_soft</item>
    </style>
    <style name="Widget.MyAunt.Chip.ReasonTagUnsure" parent="Widget.Material3.Chip.Filter">
        <item name="android:textAppearance">@style/TextAppearance.MyAunt.ChipReason</item>
        <item name="android:textColor">@color/chip_unsure_text</item>
        <item name="chipBackgroundColor">@color/chip_unsure_background</item>
        <item name="chipStrokeColor">@color/chip_unsure_stroke</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="chipCornerRadius">22dp</item>
        <item name="chipMinHeight">44dp</item>
        <item name="chipStartPadding">16dp</item>
        <item name="chipEndPadding">16dp</item>
        <item name="checkedIconVisible">false</item>
        <item name="rippleColor">@color/md_pink_soft</item>
    </style>
