<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/dialog_privacy_white_bg"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="20dp"
    android:paddingEnd="20dp"
    android:paddingBottom="20dp">

    <TextView
        android:id="@+id/tv_privacy_dialog_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="8dp"
        android:text="@string/privacy_dialog_title"
        android:textColor="@color/md_on_surface"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_privacy_intro"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:lineSpacingMultiplier="1.2"
        android:textColor="@color/md_on_surface"
        android:textSize="14sp" />

    <ScrollView
        android:id="@+id/scroll_privacy_body"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_marginTop="12dp"
        android:fillViewport="false"
        android:scrollbars="vertical">

        <TextView
            android:id="@+id/tv_privacy_body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:lineSpacingMultiplier="1.15"
            android:textColor="@color/md_on_surface"
            android:textSize="14sp" />
    </ScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_privacy_agree"
        style="@style/Widget.Material3.Button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:minHeight="52dp"
        android:text="@string/privacy_agree"
        android:textColor="@android:color/white"
        app:backgroundTint="@color/md_primary"
        app:cornerRadius="12dp" />

    <TextView
        android:id="@+id/tv_privacy_disagree"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center"
        android:padding="10dp"
        android:text="@string/privacy_disagree"
        android:textColor="@color/md_text_secondary"
        android:textSize="14sp" />
</LinearLayout>
