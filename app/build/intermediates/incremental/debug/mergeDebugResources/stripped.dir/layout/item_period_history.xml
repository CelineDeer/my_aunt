<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/md_surface"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/md_pink_soft"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="@dimen/spacing_md">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/md_on_surface"
                android:textSize="16sp"
                android:textStyle="bold"
                tools:text="2026年4月20日 星期四" />

            <TextView
                android:id="@+id/tvInterval"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/md_text_secondary"
                android:textSize="13sp"
                android:visibility="gone"
                tools:text="与上一条间隔：28 天"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/tvNoteHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@color/md_home_welcome_surface"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:text="@string/period_history_has_note"
                android:textColor="@color/md_text_secondary"
                android:textSize="12sp"
                android:visibility="gone"
                tools:visibility="visible" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnDelete"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_delete_period_record"
            android:padding="12dp"
            app:srcCompat="@drawable/ic_delete_outline_24"
            app:tint="@color/md_text_secondary"
            android:visibility="gone" />

        <ImageButton
            android:id="@+id/btnEdit"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_edit_period_record"
            android:padding="12dp"
            app:srcCompat="@drawable/ic_edit_record"
            app:tint="@color/md_text_secondary"
            android:visibility="gone" />
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
