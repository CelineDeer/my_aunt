<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ui_page_background"
    android:clipChildren="false">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_record_hub"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingBottom="@dimen/content_above_bottom_nav">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="8dp">

            <!-- 周期情境 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/md_home_welcome_surface"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tv_cycle_phase_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_alignParentTop="true"
                        android:textColor="@color/md_on_surface"
                        android:textSize="14sp"
                        tools:text="当前阶段：黄体期" />

                    <ImageButton
                        android:id="@+id/btn_cycle_calendar"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_alignParentTop="true"
                        android:layout_alignParentEnd="true"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/cd_hub_pick_record_date"
                        android:padding="8dp"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_calendar_outline" />

                    <TextView
                        android:id="@+id/tv_cycle_days_big"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/tv_cycle_phase_label"
                        android:layout_marginTop="10dp"
                        android:layout_toStartOf="@id/btn_cycle_calendar"
                        android:textColor="@color/md_primary"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        tools:text="距下次月经约 10 天" />

                    <TextView
                        android:id="@+id/tv_link_change_on_home"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/tv_cycle_days_big"
                        android:layout_marginTop="12dp"
                        android:background="?attr/selectableItemBackground"
                        android:paddingVertical="4dp"
                        android:text="@string/record_hub_link_home_period"
                        android:textColor="@color/md_primary_soft"
                        android:textSize="13sp" />
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 健康分析 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/md_surface"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/chip_reason_stroke_unchecked"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/record_hub_health_analysis_title"
                        android:textColor="@color/md_on_surface"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_analysis_tip"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:drawablePadding="10dp"
                        android:gravity="center_vertical"
                        android:textColor="@color/md_on_surface"
                        android:textSize="14sp"
                        app:drawableStartCompat="@drawable/ic_check_circle_small"
                        tools:text="提示：当前阶段属于正常现象" />

                    <TextView
                        android:id="@+id/tv_analysis_suggestion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:drawablePadding="10dp"
                        android:gravity="center_vertical"
                        android:textColor="@color/md_on_surface"
                        android:textSize="14sp"
                        app:drawableStartCompat="@drawable/ic_sunface"
                        tools:text="建议：多喝温水，保持规律作息" />

                    <TextView
                        android:id="@+id/tv_analysis_disclaimer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/record_hub_analysis_disclaimer"
                        android:textColor="@color/md_text_secondary"
                        android:textSize="11sp"
                        android:textStyle="italic" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 记录今日状态 -->
            <LinearLayout
                android:id="@+id/section_record"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/record_hub_section_today"
                    android:textColor="@color/md_on_surface"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_record_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:padding="6dp"
                    android:textColor="@color/md_text_secondary"
                    android:textSize="14sp"
                    tools:text="2026年04月30日" />
            </LinearLayout>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_quick_dry"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardBackgroundColor="@color/md_surface"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/chip_reason_stroke_unchecked"
                    app:strokeWidth="1dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="120dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <FrameLayout
                                android:id="@+id/fl_icon_dry"
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:background="@drawable/bg_hub_history_icon">

                                <ImageView
                                    android:layout_width="26dp"
                                    android:layout_height="26dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_water_drop"
                                    app:tint="@color/md_primary_soft" />
                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="@string/record_hub_quick_dry"
                                android:textColor="@color/md_on_surface"
                                android:textSize="15sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <ImageView
                            android:id="@+id/iv_check_dry"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="top|end"
                            android:layout_margin="8dp"
                            android:src="@drawable/ic_check_circle_small"
                            android:visibility="gone"
                            tools:visibility="visible" />
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_quick_thick"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardBackgroundColor="@color/md_surface"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/chip_reason_stroke_unchecked"
                    app:strokeWidth="1dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="120dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <FrameLayout
                                android:id="@+id/fl_icon_thick"
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:background="@drawable/bg_hub_history_icon">

                                <ImageView
                                    android:layout_width="26dp"
                                    android:layout_height="26dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_texture_thick"
                                    app:tint="@color/md_primary_soft" />
                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="@string/record_hub_quick_thick"
                                android:textColor="@color/md_on_surface"
                                android:textSize="15sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <ImageView
                            android:id="@+id/iv_check_thick"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="top|end"
                            android:layout_margin="8dp"
                            android:src="@drawable/ic_check_circle_small"
                            android:visibility="gone" />
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_quick_milky"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardBackgroundColor="@color/md_surface"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/chip_reason_stroke_unchecked"
                    app:strokeWidth="1dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="120dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <FrameLayout
                                android:id="@+id/fl_icon_milky"
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:background="@drawable/bg_hub_history_icon">

                                <ImageView
                                    android:layout_width="28dp"
                                    android:layout_height="28dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_color_circle_white" />
                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="@string/record_hub_quick_milky"
                                android:textColor="@color/md_on_surface"
                                android:textSize="15sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <ImageView
                            android:id="@+id/iv_check_milky"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="top|end"
                            android:layout_margin="8dp"
                            android:src="@drawable/ic_check_circle_small"
                            android:visibility="gone" />
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_quick_stretchy"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardBackgroundColor="@color/md_surface"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/chip_reason_stroke_unchecked"
                    app:strokeWidth="1dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="120dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <FrameLayout
                                android:id="@+id/fl_icon_stretchy"
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:background="@drawable/bg_hub_history_icon">

                                <ImageView
                                    android:layout_width="26dp"
                                    android:layout_height="26dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_texture_egg"
                                    app:tint="@color/md_primary_soft" />
                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="@string/record_hub_quick_stretchy"
                                android:textColor="@color/md_on_surface"
                                android:textSize="15sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <ImageView
                            android:id="@+id/iv_check_stretchy"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="top|end"
                            android:layout_margin="8dp"
                            android:src="@drawable/ic_check_circle_small"
                            android:visibility="gone" />
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>
            </GridLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save_record"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="20dp"
                android:backgroundTint="@color/md_primary"
                android:text="@string/record_hub_save"
                android:textAllCaps="false"
                android:textColor="@color/md_surface"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="28dp" />

            <!-- 历史 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:text="@string/record_hub_history_title"
                android:textColor="@color/md_on_surface"
                android:textSize="18sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_hub_history"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never"
                tools:itemCount="3"
                tools:listitem="@layout/item_discharge_hub_history" />

            <TextView
                android:id="@+id/tv_history_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingVertical="24dp"
                android:text="@string/record_hub_history_empty"
                android:textColor="@color/md_text_secondary"
                android:textSize="14sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_view_more_history"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingVertical="16dp"
                android:text="@string/record_hub_view_more"
                android:textColor="@color/md_primary_soft"
                android:textSize="14sp"
                android:visibility="gone"
                tools:visibility="visible" />

            <View
                android:layout_width="match_parent"
                android:layout_height="24dp" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_quick_add"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="@dimen/content_above_bottom_nav"
        android:contentDescription="@string/cd_hub_fab_today"
        android:src="@drawable/ic_plus"
        app:backgroundTint="@color/md_primary"
        app:tint="@color/md_surface" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
