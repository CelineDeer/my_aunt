<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ui_page_background"
    android:orientation="vertical">

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tab_layout_record_book"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/md_surface"
        android:paddingBottom="@dimen/spacing_xs"
        app:tabIndicatorColor="@color/md_primary"
        app:tabIndicatorFullWidth="false"
        app:tabMode="fixed"
        app:tabRippleColor="@color/md_pink_soft"
        app:tabSelectedTextColor="@color/md_primary"
        app:tabTextAppearance="@style/TextAppearance.Material3.TitleSmall"
        app:tabTextColor="@color/md_text_secondary" />

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/view_pager_record_book"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
