<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_hand_pattern"
    android:clipChildren="false"
    android:orientation="vertical">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollHome"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:minHeight="0dp"
        android:overScrollMode="ifContentScrolls">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="40dp"
            android:paddingBottom="@dimen/page_padding_bottom">

            <!-- 顶部：日期 + 问候（与 doc 一致，无大卡片） -->
            <LinearLayout
                android:id="@+id/cardGreeting"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_lg"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvHomePredictionLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:letterSpacing="0.08"
                        android:textAllCaps="true"
                        android:textColor="@color/ui_greeting_kicker"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        tools:text="2026年04月20日" />

                    <TextView
                        android:id="@+id/tvGreeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textColor="@color/md_primary"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        tools:text="早安，悦悦 ✨" />

                    <TextView
                        android:id="@+id/tvTodayLine"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textColor="@color/md_text_secondary"
                        android:textSize="12sp"
                        android:visibility="gone" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/ivHomeBloom"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_header_avatar"
                    android:contentDescription="@null"
                    android:padding="8dp"
                    android:src="@drawable/ic_sunface" />
            </LinearLayout>

            <!-- 中央表盘 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardMainStats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_xl"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <FrameLayout
                    android:id="@+id/layoutMainDial"
                    android:layout_width="280dp"
                    android:layout_height="280dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/bg_home_circle"
                        tools:ignore="ContentDescription" />

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="top|end"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:layout_marginEnd="0dp"
                        android:src="@drawable/ic_home_bloom"
                        tools:ignore="ContentDescription" />

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="bottom|start"
                        android:layout_marginStart="4dp"
                        android:layout_marginBottom="48dp"
                        android:src="@drawable/ic_raincloud"
                        tools:ignore="ContentDescription" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvDaysLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="距离下次月经还有"
                            android:textColor="@color/ui_dial_muted"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvDaysCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="-4dp"
                            android:layout_marginBottom="-4dp"
                            android:includeFontPadding="false"
                            android:lineSpacingExtra="0dp"
                            android:text="--"
                            android:textColor="@color/ui_dial_number"
                            android:textSize="72sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvLastDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="@dimen/spacing_md"
                            android:text="天"
                            android:textColor="@color/md_primary_soft"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvCycleInfo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_cycle_day_tag"
                            android:backgroundTint="@color/ui_chart_stats_pink_surface"
                            android:paddingHorizontal="@dimen/spacing_md"
                            android:paddingVertical="@dimen/spacing_xs"
                            android:text="当前阶段"
                            android:textColor="@color/md_primary"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <include
                android:id="@+id/hormoneDetector"
                layout="@layout/hormone_detector_module"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md" />

            <!-- 今日贴心建议（橙色系卡片） -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardWarmTip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardBackgroundColor="@color/ui_warm_card_bg"
                app:cardCornerRadius="@dimen/card_radius_lg"
                app:cardElevation="0dp"
                app:strokeColor="@color/ui_card_border_soft"
                app:strokeWidth="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/spacing_lg"
                    android:paddingTop="@dimen/spacing_lg"
                    android:paddingBottom="@dimen/spacing_lg">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:layout_marginEnd="@dimen/spacing_md"
                        app:cardBackgroundColor="@color/md_surface"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeColor="#FFEDD5"
                        app:strokeWidth="2dp">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_home_heart_v2"
                            app:tint="@color/ui_warm_title" />
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="@dimen/spacing_sm"
                            android:text="今日贴心建议"
                            android:textColor="@color/ui_warm_title"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvWarmTip"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:lineSpacingMultiplier="1.3"
                            android:text="处于贴心建议部分..."
                            android:textColor="@color/ui_warm_body"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 记录陪伴（横向滚动） -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardJourney"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/ui_companion_card_bg"
                app:cardCornerRadius="@dimen/card_radius_lg"
                app:cardElevation="0dp"
                app:strokeColor="@color/ui_card_border_soft"
                app:strokeWidth="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_home_heart_v2"
                            app:tint="@color/ui_companion_chip_text" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="记录陪伴"
                            android:textColor="@color/ui_companion_title"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="80dp"
                                android:layout_height="96dp"
                                android:layout_marginEnd="12dp"
                                android:background="@drawable/bg_companion_chip_inner"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:padding="8dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="😄"
                                    android:textSize="28sp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="6dp"
                                    android:text="心情好"
                                    android:textColor="@color/ui_companion_chip_text"
                                    android:textSize="10sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="80dp"
                                android:layout_height="96dp"
                                android:layout_marginEnd="12dp"
                                android:background="@drawable/bg_companion_chip_inner"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:padding="8dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="✨"
                                    android:textSize="28sp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="6dp"
                                    android:text="皮肤亮"
                                    android:textColor="@color/ui_companion_chip_text"
                                    android:textSize="10sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="80dp"
                                android:layout_height="96dp"
                                android:layout_marginEnd="12dp"
                                android:background="@drawable/bg_companion_chip_inner"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:padding="8dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="😴"
                                    android:textSize="28sp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="6dp"
                                    android:text="睡得香"
                                    android:textColor="@color/ui_companion_chip_text"
                                    android:textSize="10sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <FrameLayout
                                android:layout_width="80dp"
                                android:layout_height="96dp"
                                android:background="@drawable/bg_companion_add_dashed">

                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:layout_gravity="center"
                                    android:contentDescription="@null"
                                    android:src="@drawable/ic_plus"
                                    app:tint="@color/ui_companion_chip_text" />
                            </FrameLayout>
                        </LinearLayout>
                    </HorizontalScrollView>

                    <TextView
                        android:id="@+id/tvJourneySummary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:lineSpacingMultiplier="1.15"
                        android:textColor="@color/md_secondary"
                        android:textSize="11sp"
                        android:visibility="gone"
                        tools:text=""
                        tools:visibility="visible" />

                    <LinearLayout
                        android:id="@+id/layoutJourneyActions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnOpenChart"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:minHeight="44dp"
                            android:text="@string/home_journey_open_chart"
                            android:textAllCaps="false"
                            android:textColor="@color/md_primary"
                            app:rippleColor="@color/md_pink_soft" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnOpenPeriodHistory"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:minHeight="44dp"
                            android:text="@string/home_open_period_history"
                            android:textAllCaps="false"
                            android:textColor="@color/md_primary"
                            app:rippleColor="@color/md_pink_soft" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/spacing_xl" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
