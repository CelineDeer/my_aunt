<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/md_bg"
    android:clipChildren="false">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollHome"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:minHeight="0dp"
        android:fillViewport="true"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:overScrollMode="ifContentScrolls">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:paddingBottom="12dp"
            android:clipChildren="false"
            android:clipToPadding="false">

            <androidx.cardview.widget.CardView
                android:id="@+id/cardGreeting"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="22dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/md_home_welcome_surface"
                app:strokeColor="@color/md_pink_soft"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvHomePredictionLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/home_mood_section_title"
                            android:textSize="13sp"
                            android:textColor="@color/md_text_secondary" />

                        <TextView
                            android:id="@+id/tvGreeting"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="@color/md_on_surface"
                            tools:text="可能在「慢慢回血期」" />

                        <TextView
                            android:id="@+id/tvTodayLine"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:textSize="14sp"
                            android:textColor="@color/md_text_secondary"
                            android:lineSpacingMultiplier="1.15"
                            tools:text="雌激素逐渐升高…" />

                    </LinearLayout>

                    <ImageView
                        android:id="@+id/ivHomeBloom"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:importantForAccessibility="no"
                        android:src="@drawable/ic_home_bloom"
                        android:contentDescription="@null" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardMainStats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:cardCornerRadius="24dp"
                app:cardBackgroundColor="@color/md_surface"
                app:strokeColor="@color/md_pink_soft"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:id="@+id/tvDaysCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textSize="64sp"
                        android:textStyle="bold"
                        android:textColor="@color/md_primary" />

                    <TextView
                        android:id="@+id/tvDaysLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="距离上次姨妈已经"
                        android:textSize="18sp"
                        android:textColor="@color/md_on_surface" />

                    <TextView
                        android:id="@+id/tvLastDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:textSize="15sp"
                        android:textColor="@color/md_text_secondary"
                        android:text="等待第一次记录 🌸" />

                    <TextView
                        android:id="@+id/tvCycleInfo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:textSize="15sp"
                        android:textColor="@color/md_secondary"
                        android:visibility="gone" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardWarmTip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/md_home_tip_surface"
                app:strokeColor="@color/md_pink_soft"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/home_tip_title"
                        android:textColor="@color/md_on_surface"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvWarmTip"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:lineSpacingMultiplier="1.15"
                        android:textColor="@color/md_text_secondary"
                        android:textSize="14sp"
                        tools:text="小贴士示例" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardJourney"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="@color/md_surface"
                app:strokeColor="@color/md_pink_soft"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/home_journey_title"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/md_on_surface" />

                    <TextView
                        android:id="@+id/tvJourneySummary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:textSize="14sp"
                        android:lineSpacingMultiplier="1.12"
                        android:textColor="@color/md_text_secondary"
                        tools:text="@string/home_journey_empty" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnOpenChart"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:minHeight="44dp"
                        android:text="@string/home_journey_open_chart"
                        android:textAllCaps="false"
                        android:textColor="@color/md_primary"
                        android:visibility="gone"
                        app:rippleColor="@color/md_pink_soft" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <androidx.cardview.widget.CardView
        android:id="@+id/barHomeActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="12dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:clipToOutline="false"
        app:cardCornerRadius="22dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="@color/md_surface"
        app:strokeColor="@color/md_pink_soft"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="14dp"
            android:clipChildren="false"
            android:clipToPadding="false">

            <TextView
                android:id="@+id/tvSuccessHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:gravity="center"
                android:text="已记录，抱抱你，照顾好自己"
                android:textColor="@color/md_secondary"
                android:textSize="14sp"
                android:visibility="gone" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:paddingVertical="4dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRecord"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="记录今天"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    app:cornerRadius="18dp"
                    android:backgroundTint="@color/md_primary" />
            </FrameLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBackfill"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:minHeight="48dp"
                android:text="补录其他日期"
                android:textAllCaps="false"
                android:textColor="@color/md_primary"
                app:cornerRadius="18dp"
                app:strokeColor="@color/md_primary" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>
