<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/md_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvChartHeadline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="每月周期间隔"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/md_on_surface" />

        <TextView
            android:id="@+id/tvChartLegend"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="20–24天紫色，25–32天绿色，33–40天黄色；小于20或大于40天为异常（红色）。长按柱子可查看备注"
            android:textSize="13sp"
            android:textColor="@color/md_text_secondary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPickMonth"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="选择日期范围" />

        <TextView
            android:id="@+id/tvWindowRange"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text=""
            android:textColor="@color/md_text_secondary"
            android:textSize="13sp" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardChartArea"
            android:layout_width="match_parent"
            android:layout_height="320dp"
            android:layout_marginTop="14dp"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="@color/md_surface">

            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/chartPager"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clickable="true"
                android:focusable="true" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="记录两次以上后，才可以看到周期柱状图"
            android:textSize="14sp"
            android:textColor="@color/md_text_secondary" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardStats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/md_surface"
            app:strokeColor="@color/md_pink_soft"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="记录周期数"
                        android:textColor="@color/md_text_secondary" />

                    <TextView
                        android:id="@+id/tvRecordCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/md_on_surface"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="平均周期"
                        android:textColor="@color/md_text_secondary" />

                    <TextView
                        android:id="@+id/tvAvgCycle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/md_on_surface"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="最短 / 最长"
                        android:textColor="@color/md_text_secondary" />

                    <TextView
                        android:id="@+id/tvMinCycle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/md_on_surface"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="  /  "
                        android:textColor="@color/md_text_secondary" />

                    <TextView
                        android:id="@+id/tvMaxCycle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/md_on_surface"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="异常次数"
                        android:textColor="@color/md_text_secondary" />

                    <TextView
                        android:id="@+id/tvAbnormal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/md_chart_abnormal_text"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
